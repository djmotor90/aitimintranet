# --- Core ---
APP_BASE_URL=http://localhost:3000                              # used by worker + email links
DATABASE_URL=postgres://aitim:aitim@localhost:5432/aitim_intranet

# --- Auth.js ---
# Canonical URL for OAuth callbacks. MUST match the public domain exactly,
# including https://. Behind a reverse proxy (Traefik/Coolify), this prevents
# the OAuth redirect_uri from being built from internal container hostnames.
AUTH_URL=http://localhost:3000
AUTH_SECRET= # openssl rand -base64 32
AUTH_TRUST_HOST=true

# --- Entra ID: web app registration (interactive SSO, delegated perms) ---
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER= # https://login.microsoftonline.com/<tenant-id>/v2.0
ENTRA_TENANT_ID=

# --- Entra ID: daemon app registration (worker, application perms) ---
DAEMON_CLIENT_ID=
DAEMON_CLIENT_SECRET=

# --- Email ---
MAIL_TRANSPORT=smtp # smtp (dev: mailpit) | graph (prod)
SMTP_HOST=localhost
SMTP_PORT=1025
GRAPH_SENDER_UPN= # e.g. intranet@aitim.com

# --- Storage (S3-compatible: iDrive e2, MinIO, AWS S3, etc.) ---
S3_ENDPOINT=https://s3.us-west-1.idrivee2.com  # remove for AWS S3
S3_REGION=us-west-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_ATTACHMENTS=aitim-attachments
S3_BUCKET_PHOTOS=aitim-photos
S3_FORCE_PATH_STYLE=false  # true only for local MinIO

# --- Public forms ---
TURNSTILE_SITE_KEY=1x00000000000000000000AA # Cloudflare test key (always passes)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
